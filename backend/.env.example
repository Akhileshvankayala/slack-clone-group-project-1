# Database settings (e.g. MongoDB local or Atlas URL)
DB_URL=mongodb://localhost:27017/ChatApp

# Service port configuration (Render will assign PORT dynamically)
PORT=4000

# Secret key for JWT tokens encoding/decoding
JWT_SECRET=your_jwt_secret_key_here

# Redis cache support (Optional, set true to activate)
USE_REDIS=false
REDIS_URL=redis://localhost:6379

# Production CORS URL matching (Frontend URL)
FRONTEND_URL=http://localhost:5173,http://localhost:5174

# Production Backend base url (Optional, used if host headers resolve incorrectly)
# BACKEND_URL=https://your-backend.onrender.com

# Cloudinary Integration for permanent Profile image uploads (Optional fallback)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
